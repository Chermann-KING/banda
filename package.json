{
  "name": "banda",
  "private": true,
  "description": "Banda — UI kit monorepo. Starters front-end prêts à l'emploi avec un design system partagé.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,css,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript-eslint": "^8.30.1"
  }
}
