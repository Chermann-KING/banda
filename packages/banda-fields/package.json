{
  "name": "@banda/fields",
  "version": "0.1.0",
  "description": "Intelligence des champs Banda — sanitisation, formatage temps réel, schémas Zod, données téléphone. Framework-agnostic.",
  "type": "module",
  "license": "MIT",
  "files": ["dist", "src"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src tests",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "~5.8.3"
  }
}
