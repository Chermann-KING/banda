      "lg": "0 8px 24px rgb(23 20 17 / 0.14)",
      "xl": "0 16px 48px rgb(23 20 17 / 0.18)"
    },
    "z": {
      "dropdown": "1000",
      "sticky": "1100",
      "overlay": "1300",
      "modal": "1400",
      "toast": "1500"
    },
    "motion": {
      "duration": {
        "fast": "120ms",
        "normal": "200ms",
        "slow": "320ms"
      },
      "easing": {
        "standard": "cubic-bezier(0.2, 0, 0, 1)",
        "emphasized": "cubic-bezier(0.3, 0, 0.8, 0.15)"
      }
    }
  },
